to = NodePath("../Move")
delay_in_seconds = "0.1"

[node name="Hurt" type="AtomicState" parent="BossStateMachine/Root"]
script = ExtResource("6_hurt")

[node name="On Hurt Complete" type="Node" parent="BossStateMachine/Root/Hurt"]

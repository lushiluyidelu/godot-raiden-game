[node name="Enter" type="AtomicState" parent="BossStateMachine/Root"]
script = ExtResource("3_enter")

[node name="On Enter Complete" type="Node" parent="BossStateMachine/Root/Enter"]
script = ExtResource("transition")
to = NodePath("../Active")
delay_in_seconds = "0.5"

[node name="Active" type="CompoundState" parent="BossStateMachine/Root"]

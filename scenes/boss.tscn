[node name="On Hurt" type="Node" parent="BossStateMachine/Root"]
script = ExtResource("transition")
to = NodePath("Hurt")
event = &"take_damage"

[node name="On Phase2" type="Node" parent="BossStateMachine/Root"]
script = ExtResource("transition")
to = NodePath("Phase2")
event = &"phase2_transform"

[node name="Phase2" type="CompoundState" parent="BossStateMachine/Root"]
